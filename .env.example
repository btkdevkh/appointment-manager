# Copy the auth variables into .env.local (gitignored) and fill them in.
# DATABASE_URL / DIRECT_URL live in .env — Prisma's CLI reads that file only.

# Neon Postgres. Pooled connection for the app, direct for migrations.
# These point at the DEVELOPMENT branch — `npm run dev` reads them, so they must
# never hold production credentials.
DATABASE_URL=
DIRECT_URL=

# Production, read-only, for `npm run users:list` (the /list-users command) and
# nothing else. Optional: leave it unset and that command refuses to run, which
# is the safe default.
#
# It lives in its own gitignored file, `.env.prod.local` — NOT .env or
# .env.local — for two reasons:
#   - `vercel env pull` overwrites .env.local, which would silently delete it;
#   - Next.js auto-loads .env.local, so a production string there would sit in
#     `npm run dev`'s process environment for no reason.
# Keeping it out of .env also means the Prisma CLI never sees it and can't
# migrate production by accident.
#
# Use the credentials of a READ-ONLY Postgres role, not the owner role Neon
# hands you by default — this command only ever runs a SELECT, and a read-only
# role caps the damage if the file leaks:
#   CREATE ROLE readonly_lister WITH LOGIN PASSWORD '...';
#   GRANT CONNECT ON DATABASE neondb TO readonly_lister;
#   GRANT USAGE ON SCHEMA public TO readonly_lister;
#   GRANT SELECT ON ALL TABLES IN SCHEMA public TO readonly_lister;
#   ALTER DEFAULT PRIVILEGES IN SCHEMA public
#     GRANT SELECT ON TABLES TO readonly_lister;
#
# Build the string by hand — `vercel env pull` can't retrieve the production
# one, since DATABASE_URL is marked sensitive there and comes back as the
# literal text [SENSITIVE]. Take the production POOLED host from the Neon
# dashboard and substitute the read-only role's name and password:
#   postgresql://readonly_lister:<password>@<prod-host>-pooler.<region>.neon.tech/neondb?sslmode=require
PROD_DATABASE_URL=

# Auth.js session encryption key. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(33).toString('base64'))"
AUTH_SECRET=

# Google OAuth 2.0 client (console.cloud.google.com > APIs & Services >
# Credentials > Create credentials > OAuth client ID > Web application).
# Authorised redirect URI for local dev:
#   http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Lets preview deployments sign in, and is set in the Vercel project only —
# leave it unset locally, or your sign-ins will route through production.
# Each preview gets a URL Google won't have registered, so previews send
# Google the *production* callback instead and production forwards the result
# back to the preview. Auth.js appends `/callback/<provider>` to this value, so
# it must be the stable deployment's `/api/auth` and nothing more:
#   AUTH_REDIRECT_PROXY_URL=https://appointment-manager-gilt.vercel.app/api/auth
# It has to be set on **both** Preview and Production: Preview to send the
# proxy's URL to Google, Production so it recognises itself as the proxy and
# forwards (Auth.js decides via `new URL(redirectProxyUrl).origin === url.origin`,
# which is only evaluated when the variable is set at all). Same value in both,
# so unlike DATABASE_URL it is one entry with both scopes ticked.
# Forwarding is safe because the target origin travels in the OAuth `state`,
# signed with AUTH_SECRET — which is why AUTH_SECRET must match across the two.

# Only needed to run a production build on your own machine (`npm start`).
# Auth.js trusts the Host header when NODE_ENV isn't production (so `npm run
# dev` is fine) or when VERCEL is set (so deploys are fine) — but a local
# `npm start` is neither, and fails with:
#   UntrustedHost: Host must be trusted. URL was: http://localhost:3000/...
# Leave it out of the Vercel project's env vars; it is inferred there.
AUTH_TRUST_HOST=true
